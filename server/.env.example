# Neo4j Aura (or self-hosted)
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
# Aura: username is always "neo4j" (not the xxxxx in xxxxx.databases.neo4j.io)
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Optional. Omit to use the server's home/default graph. On many Aura instances the graph name
# equals the instance id in the URI (e.g. xxxx in xxxx.databases.neo4j.io), not "neo4j".
# Classic local Docker often uses: NEO4J_DATABASE=neo4j
# NEO4J_DATABASE=

# API
PORT=4000
JWT_SECRET=use-a-long-random-string-not-your-email
# Netlify site URL(s), no trailing slash (CORS). Multiple: comma-separated, no spaces.
FRONTEND_URL=https://your-site.netlify.app
# MUST be the public URL of THIS API (Railway), NOT Netlify. Used for Google OAuth callback.
# Local dev: http://localhost:4000
# Production: https://your-service.up.railway.app
API_PUBLIC_URL=http://localhost:4000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
